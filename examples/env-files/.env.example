# Example .env file — would normally be gitignored
# ccpm loads these at build time via env_file/env_files

ANTHROPIC_API_KEY=sk-ant-example-key-not-real
GITHUB_TOKEN=ghp_example_token_not_real
CUSTOM_SETTING=from-env-file

# Comments and blank lines are skipped

# Quoted values work too
DATABASE_URL="postgresql://localhost:5432/mydb"

# export prefix is stripped
export ANOTHER_VAR=exported-value
