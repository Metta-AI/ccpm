#!/usr/bin/env bash
set -euo pipefail

# generate-credentials â€” Extract credentials from a metta-installed machine
# into .env files for use with ccpm profiles.
#
# Usage:
#   scripts/generate-credentials [output-dir]
#   scripts/generate-credentials --help
#
# Assumes: metta install has been run. Credentials that aren't available are
# skipped with a warning. Each service gets its own .env file.

CREDS_DIR="${1:-./credentials}"
METTA_VENV="${METTA_DIR:-$HOME/metta}/.venv/bin/python"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
DIM='\033[2m'
BOLD='\033[1m'
RESET='\033[0m'

log()  { echo -e "${GREEN}[+]${RESET} $*"; }
warn() { echo -e "${YELLOW}[!]${RESET} $*"; }
err()  { echo -e "${RED}[-]${RESET} $*"; }
dim()  { echo -e "${DIM}    $*${RESET}"; }

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    echo "Usage: $(basename "$0") [output-dir]"
    echo ""
    echo "Extracts credentials from a metta-installed machine into .env files."
    echo "Default output directory: ./credentials"
    echo ""
    echo "Generated files:"
    echo "  aws-read.env          AWS credentials (standard 'softmax' profile)"
    echo "  aws-write.env         AWS credentials (admin 'softmax-admin' profile)"
    echo "  github-read.env       GitHub fine-grained read-only PAT"
    echo "  github-write.env      GitHub token from gh CLI (full access)"
    echo "  wandb.env             Weights & Biases API key"
    echo "  bedrock.env           AWS Bedrock / Claude env vars"
    echo "  observatory.env       Observatory API token"
    exit 0
fi

mkdir -p "$CREDS_DIR"
echo -e "${BOLD}Generating credentials into ${CREDS_DIR}/${RESET}"
echo ""

GENERATED=0
SKIPPED=0

write_env() {
    local file="$1"
    shift
    local path="${CREDS_DIR}/${file}"
    : > "$path"
    chmod 600 "$path"
    for pair in "$@"; do
        echo "$pair" >> "$path"
    done
    log "Wrote ${file} ($(wc -l < "$path") vars)"
    GENERATED=$((GENERATED + 1))
}

skip() {
    warn "Skipped $1: $2"
    SKIPPED=$((SKIPPED + 1))
}

# ============================================================================
# AWS â€” read (softmax) and write (softmax-admin)
# ============================================================================

generate_aws() {
    local profile="$1"
    local label="$2"
    local outfile="$3"

    if ! aws configure list-profiles 2>/dev/null | grep -qx "$profile"; then
        skip "$outfile" "AWS profile '$profile' not configured"
        return
    fi

    local creds
    creds=$(aws configure export-credentials --format env-no-export --profile "$profile" 2>/dev/null) || {
        skip "$outfile" "AWS SSO session expired for '$profile' â€” run: aws sso login --profile $profile"
        return
    }

    # Parse into KEY=VALUE pairs
    local pairs=()
    while IFS= read -r line; do
        [[ -n "$line" ]] && pairs+=("$line")
    done <<< "$creds"
    pairs+=("AWS_PROFILE=$profile")
    pairs+=("AWS_REGION=us-east-1")

    write_env "$outfile" "${pairs[@]}"
    local expiry
    expiry=$(echo "$creds" | grep AWS_CREDENTIAL_EXPIRATION | cut -d= -f2)
    [[ -n "$expiry" ]] && dim "Expires: $expiry"
}

generate_aws "softmax" "read" "aws-read.env"
generate_aws "softmax-admin" "write" "aws-write.env"

# ============================================================================
# GitHub â€” write (gh auth token) and read (fine-grained PAT)
# ============================================================================

generate_github_write() {
    if ! command -v gh &>/dev/null; then
        skip "github-write.env" "gh CLI not installed"
        return
    fi

    if ! gh auth status &>/dev/null; then
        skip "github-write.env" "gh not authenticated â€” run: gh auth login"
        return
    fi

    local token
    token=$(gh auth token 2>/dev/null) || {
        skip "github-write.env" "Could not retrieve gh token"
        return
    }

    local user
    user=$(gh api user --jq .login 2>/dev/null || echo "unknown")

    write_env "github-write.env" \
        "GITHUB_TOKEN=$token" \
        "GH_TOKEN=$token" \
        "GITHUB_USER=$user"

    local scopes
    scopes=$(gh auth status 2>&1 | grep "Token scopes" | sed "s/.*Token scopes: //")
    dim "User: $user | Scopes: $scopes"
}

generate_github_read() {
    if ! command -v gh &>/dev/null; then
        skip "github-read.env" "gh CLI not installed"
        return
    fi

    if ! gh auth status &>/dev/null; then
        skip "github-read.env" "gh not authenticated"
        return
    fi

    # Check if user already has a GITHUB_READ_TOKEN env var
    if [[ -n "${GITHUB_READ_TOKEN:-}" ]]; then
        local user
        user=$(gh api user --jq .login 2>/dev/null || echo "unknown")
        write_env "github-read.env" \
            "GITHUB_TOKEN=$GITHUB_READ_TOKEN" \
            "GH_TOKEN=$GITHUB_READ_TOKEN" \
            "GITHUB_USER=$user"
        dim "Used existing GITHUB_READ_TOKEN env var"
        return
    fi

    # Try to create a classic PAT via the API with read-only scopes
    # GitHub doesn't support fully automated PAT creation, so we prompt
    local user
    user=$(gh api user --jq .login 2>/dev/null || echo "unknown")

    echo ""
    echo -e "  ${BOLD}GitHub read-only token setup${RESET}"
    echo -e "  A read-only token needs to be created via GitHub's web UI."
    echo -e "  Opening the creation page with pre-filled read-only scopes..."
    echo ""

    local create_url="https://github.com/settings/tokens/new?scopes=repo:status,read:org,read:user,read:packages&description=ccpm-read-token"

    # Try to open browser
    if command -v open &>/dev/null; then
        open "$create_url" 2>/dev/null || true
    elif command -v xdg-open &>/dev/null; then
        xdg-open "$create_url" 2>/dev/null || true
    else
        echo -e "  ${DIM}Create token at: ${create_url}${RESET}"
    fi

    echo -e "  Paste the token here (or press Enter to skip):"
    if [[ -t 0 ]]; then
        read -r -p "  > " read_token </dev/tty
    else
        # Non-interactive â€” skip
        read_token=""
    fi

    if [[ -z "$read_token" ]]; then
        skip "github-read.env" "No token provided (set GITHUB_READ_TOKEN or create one later)"
        echo -e "  ${DIM}Tip: export GITHUB_READ_TOKEN=ghp_... and re-run${RESET}"
        return
    fi

    write_env "github-read.env" \
        "GITHUB_TOKEN=$read_token" \
        "GH_TOKEN=$read_token" \
        "GITHUB_USER=$user"
}

generate_github_write
generate_github_read

# ============================================================================
# Weights & Biases
# ============================================================================

generate_wandb() {
    local key=""

    # 1. Check env var
    if [[ -n "${WANDB_API_KEY:-}" ]]; then
        key="$WANDB_API_KEY"
    fi

    # 2. Check ~/.netrc
    if [[ -z "$key" && -f "$HOME/.netrc" ]]; then
        key=$(awk '/machine api.wandb.ai/{getline; getline; print $2}' "$HOME/.netrc" 2>/dev/null || true)
    fi

    # 3. Try wandb CLI
    if [[ -z "$key" ]] && command -v wandb &>/dev/null; then
        key=$(wandb api-key 2>/dev/null || true)
    fi

    # 4. Try via metta venv
    if [[ -z "$key" && -x "$METTA_VENV" ]]; then
        key=$("$METTA_VENV" -c "
import netrc, os
key = os.environ.get('WANDB_API_KEY', '')
if not key:
    try:
        n = netrc.netrc()
        auth = n.authenticators('api.wandb.ai')
        if auth: key = auth[2]
    except: pass
if not key:
    try:
        import wandb
        key = wandb.api.api_key or ''
    except: pass
print(key)
" 2>/dev/null || true)
    fi

    if [[ -z "$key" ]]; then
        skip "wandb.env" "W&B API key not found â€” run: wandb login"
        return
    fi

    write_env "wandb.env" \
        "WANDB_API_KEY=$key" \
        "WANDB_ENTITY=metta-research" \
        "WANDB_PROJECT=metta"
}

generate_wandb

# ============================================================================
# AWS Bedrock / Claude env vars
# ============================================================================

generate_bedrock() {
    # These are static config vars, not secrets â€” always generate
    write_env "bedrock.env" \
        "CLAUDE_CODE_USE_BEDROCK=1" \
        "AWS_REGION=us-east-1" \
        "ANTHROPIC_MODEL=us.anthropic.claude-opus-4-6-v1" \
        "ANTHROPIC_SMALL_FAST_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0"
}

generate_bedrock

# ============================================================================
# Observatory
# ============================================================================

generate_observatory() {
    if [[ ! -x "$METTA_VENV" ]]; then
        skip "observatory.env" "Metta venv not found at $METTA_VENV"
        return
    fi

    local token
    token=$("$METTA_VENV" -c "
from cogames.token_storage import TokenKind, load_token
token = load_token(token_kind=TokenKind.OBSERVATORY, server='https://api.observatory.softmax-research.net')
print(token or '')
" 2>/dev/null) || true

    if [[ -z "$token" ]]; then
        skip "observatory.env" "Observatory token not found â€” run: metta install (SOFTMAX profile)"
        return
    fi

    write_env "observatory.env" \
        "OBSERVATORY_TOKEN=$token" \
        "OBSERVATORY_URL=https://api.observatory.softmax-research.net"
}

generate_observatory

# ============================================================================
# Summary
# ============================================================================

echo ""
echo -e "${BOLD}Done.${RESET} Generated ${GREEN}${GENERATED}${RESET} credential files, skipped ${YELLOW}${SKIPPED}${RESET}."
echo ""

if [[ $GENERATED -gt 0 ]]; then
    echo -e "${DIM}Files in ${CREDS_DIR}/:${RESET}"
    ls -la "$CREDS_DIR"/*.env 2>/dev/null | awk '{print "  " $1, $NF}' | sed "s|$CREDS_DIR/||2"
    echo ""
    echo -e "${DIM}Usage in a ccpm profile:${RESET}"
    echo -e "${DIM}  [env]${RESET}"
    echo -e "${DIM}  env_files = [\"credentials/aws-read.env\", \"credentials/bedrock.env\"]${RESET}"
    echo ""
    echo -e "${YELLOW}These files contain secrets. Add 'credentials/' to .gitignore.${RESET}"
fi
